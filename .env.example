# OpenAI
OPENAI_API_KEY=sk-replace-me

# LLM / Embeddings
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.1
EMBEDDINGS_MODEL=text-embedding-3-small

# RAG
FAISS_INDEX_PATH=./data/faiss_index
CONFIDENCE_THRESHOLD=0.65
PLN_TIMEOUT_SECONDS=10

# Banco de dados
DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
